---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Zulassungsdienst Kennwerk | Zulassung in unter 10 Minuten</title>
<meta name="description" content="Kfz-Zulassung in unter 10 Minuten – deutschlandweit & 24/7. Anmeldung, Ummeldung, Abmeldung, Wunschkennzeichen. Bequem per WhatsApp, ohne Termin beim Straßenverkehrsamt." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%231e40af%22/><text x=%2250%22 y=%2274%22 font-family=%22Arial, sans-serif%22 font-size=%2264%22 font-weight=%22bold%22 fill=%22white%22 text-anchor=%22middle%22>D</text></svg>">
<link rel="stylesheet" href={import.meta.env.BASE_URL + "styles/system.css"}>
</head>
<body>
  <Header />
  <slot />
  <Footer />

  <!-- Sticky Mobile CTA -->
  <div class="mobile-cta">
    <a href={import.meta.env.BASE_URL + "auftrag"} class="btn-orange" style="border-radius:12px;flex:1.5;box-shadow:var(--glow-orange)">
      Auftrag starten
    </a>
    <a href="https://wa.me/491728474357" target="_blank" rel="noopener" class="btn-wa" style="border-radius:12px;flex:1">
      <svg viewBox="0 0 448 512" fill="currentColor" style="margin-right:4px"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.2-157zM223.9 438.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.5-186.6 184.5zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg> WhatsApp
    </a>
  </div>

  <script is:inline>
    // Mobile menu toggle
    function toggleMenu(btn){
      var nav = document.getElementById('mobileNav');
      if (nav) {
        var open = nav.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
    }
    function closeMenu(){
      var nav = document.getElementById('mobileNav');
      if (nav) nav.classList.remove('open');
      var btn = document.querySelector('.hamburger');
      if (btn) btn.setAttribute('aria-expanded','false');
    }

    // 10-Minuten Checker (for index page)
    let isEligible = true;
    function nextStep(currentStep, answer){
      if(!answer) isEligible = false;
      var elCur = document.getElementById('step-' + currentStep);
      var elNext = document.getElementById('step-' + (currentStep + 1));
      if (elCur) elCur.classList.add('hidden');
      if (elNext) elNext.classList.remove('hidden');
    }
    function showResult(answer){
      if(!answer) isEligible = false;
      document.querySelectorAll('.checker-step').forEach(el => el.classList.add('hidden'));
      var elRes = document.getElementById(isEligible ? 'result-success' : 'result-manual');
      if (elRes) elRes.classList.remove('hidden');
    }
    function resetChecker(){
      isEligible = true;
      document.querySelectorAll('.checker-step').forEach(el => el.classList.add('hidden'));
      var s1 = document.getElementById('step-1');
      if (s1) s1.classList.remove('hidden');
    }
  </script>
</body>
</html>
