<!-- ════════ 10-Minuten Checker ════════ -->
<section id="checker" class="section bg-soft">
  <div class="wrap wrap-narrow">
    <div class="sec-head" data-aos="fade-up">
      <h2 class="h2 uppercase">Der 4-Schritte-Check</h2>
      <div class="sec-rule"></div>
      <p class="lead">Prüfe in 4 Klicks, ob dein Fahrzeug für die digitale Express-Zulassung geeignet ist.</p>
    </div>

    <div class="checker-box" id="checker-container" data-aos="zoom-in">
      <!-- Q1 -->
      <div id="step-1" class="checker-step">
        <div class="q-label">Frage 1 von 4</div>
        <h3>Wurde Ihr Fahrzeugschein (Zulassungsbescheinigung Teil I) nach dem 01.01.2015 ausgestellt?</h3>
