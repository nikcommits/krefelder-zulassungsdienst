            Anrufen
          </a>
        </div>
      </div>
      <div class="hero-media" data-aos="fade-left">
        <div class="frame"><img src={import.meta.env.BASE_URL + "/assets/images/hero-new.webp"} alt="Übergabe der Kennzeichen nach erfolgreicher Zulassung" width="800" height="600"></div>
      </div>
    </div>

    <!-- Services slanted bar -->
    <div class="services">
      <div class="wrap wrap-md inner">
        <div class="title">
          <h2>Unsere Services</h2>
          <div class="u"></div>
        </div>
        <div class="body">
          <div class="services-grid">
            <div class="item"><span class="chk"><svg viewBox="0 0 448 512" fill="currentColor"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg></span> Wunschkennzeichen</div>
            <div class="item"><span class="chk"><svg viewBox="0 0 448 512" fill="currentColor"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg></span> Autokennzeichen</div>
            <div class="item"><span class="chk"><svg viewBox="0 0 448 512" fill="currentColor"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg></span> An- &amp; Ummeldung</div>
            <div class="item"><span class="chk"><svg viewBox="0 0 448 512" fill="currentColor"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg></span> Saisonkennzeichen</div>
